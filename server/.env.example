# FoodPrint 私有 DB — server 環境變數範本
# 複製成 .env 後填入你自己的值；.env 不會進版控。
#
#   docker compose up -d --build   會自動讀同目錄的 .env

# Postgres 連線（請改掉預設密碼）
POSTGRES_USER=foodprint
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=foodprint

# API 對外埠（預設 8000）；install.sh 會自動避開已被占用的埠並覆寫這裡。
API_PORT=8000

# 地圖前端對外埠（預設 8080）；同樣由 install.sh 自動避埠。
WEB_PORT=8080

# 存取 token（強烈建議設定；空字串=純內網信任、不檢查）
#   FOODPRINT_TOKEN       讀寫：入庫 / 改 tag / 刪除 / 取原圖
#   FOODPRINT_READ_TOKEN  唯讀：只能查詢 + 取縮圖
# 產一組隨機 token：  python3 -c "import secrets; print(secrets.token_hex(32))"
FOODPRINT_TOKEN=
FOODPRINT_READ_TOKEN=

# 地圖前端的 nginx 反向代理會以此 token 代打唯讀端點（瀏覽器端不持 token）。
# install.sh 自動填成 FOODPRINT_READ_TOKEN（沒有就用 FOODPRINT_TOKEN）。
FOODPRINT_PROXY_TOKEN=

# CORS 來源（未來的地圖前端跨源讀取用）；預設放行所有來源，讀取仍受 token 把關。
# 要收斂：FOODPRINT_CORS_ORIGINS=https://food.example.com,http://192.168.1.50:8080
FOODPRINT_CORS_ORIGINS=*

# /search /stats /nearby 速率限制（預設 60/分鐘）
FOODPRINT_SEARCH_RATE=60/minute

# GET /skill 下載限區網（看真實對端 IP）。要額外放行非私網來源（如 VPN 子網），
# 在這裡填逗號分隔的 CIDR；留空＝只放私有網段 + loopback。
FOODPRINT_SKILL_ALLOW_CIDRS=
